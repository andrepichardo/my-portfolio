generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
}

model Project {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String
  technologies String
  techList     String[]
  imageUrl     String
  demoUrl      String?
  codeUrl      String?
  note         String?
  displayOrder Int      @default(0)
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
